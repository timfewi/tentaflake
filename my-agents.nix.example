# ─────────────────────────────────────────────────────────────────────
# my-agents.nix.example — Hermes agent definitions for Tentaflake
#
# Define your agents here. Each call to mkHermesAgent creates one
# fully isolated agent with:
#   - Separate Docker container (host networking)
#   - Separate system user + group (hermes-<name>)
#   - Separate state directory (/var/lib/hermes-<name>)
#   - Separate API key (via env file in /run/secrets/)
#   - Auto-start on boot (unless autoStart = false)
#
# Quick start:
#   1. Copy this file:    cp my-agents.nix.example my-agents.nix
#   2. Create env files:  sudo cp hermes.env.example /run/secrets/hermes-coding.env
#                         sudo chmod 600 /run/secrets/hermes-coding.env
#                         sudo vi /run/secrets/hermes-coding.env
#   3. Rebuild:           sudo nixos-rebuild switch --flake .#agent-host
#
# Each secret file must contain at minimum:
#   OPENROUTER_API_KEY=sk-or-...
#
# See hermes.env.example for all supported variables.
# ─────────────────────────────────────────────────────────────────────

{ mkHermesAgent }:

# mkHermesAgent parameters (all optional except name):
#
#   name               Unique agent name (used for container, user, state dir)
#   stateDir           State directory path (default: /var/lib/hermes-<name>)
#   user               System user name (default: hermes-<name>)
#   group              System group name (default: hermes-<name>)
#   uid                Force numeric UID (default: auto-assigned)
#   gid                Force numeric GID (default: auto-assigned)
#   image              OCI container image (default: ghcr.io/nousresearch/hermes-agent:latest)
#   envFile            Path to .env file on host (injected into container)
#   agenixFile         Path to agenix-managed secret (alternative to envFile)
#   extraVolumes       List of host:container:mode volume mounts (e.g. [ "/home/user/projects:/projects:ro" ])
#   extraEnvironment   Attrset of extra env vars for the container
#   cmd                Container entrypoint command (default: [ "gateway", "run", "--replace" ])
#   autoStart          Start container with systemd (default: true)
#   createUser         Create system user/group (default: true)
#   extraContainerConfig  Extra attrset merged into OCI container config
#   settings           Attrset → Hermes config.yaml (auto-generated, mounted at $HERMES_HOME/config.yaml).
#                      Default: null (use built-in defaults). Set to {} for empty config.
#                      Changes: nixos-rebuild → docker restart hermes-<name>
#

[
  # ═══════════════════════════════════════════════════════════
  # Active agents — uncommented, ready to use after env setup
  # ═══════════════════════════════════════════════════════════

  # ── Coding agent ──────────────────────────────────────────
  # Profile with tool-progress disabled, access to host projects.
  (mkHermesAgent {
    name    = "coding";
    envFile = "/run/secrets/hermes-coding.env";

    extraEnvironment = {
      HERMES_PROFILE              = "coding";
      HERMES_DISPLAY_TOOL_PROGRESS = "off";
    };

    extraVolumes = [
      "/home/admin/projects:/home/admin/projects:ro"
    ];
  })

  # ── Research agent ────────────────────────────────────────
  # Profile with Firecrawl web backend, access to research data.
  (mkHermesAgent {
    name    = "research";
    envFile = "/run/secrets/hermes-research.env";

    extraEnvironment = {
      HERMES_PROFILE     = "research";
      HERMES_WEB_BACKEND = "firecrawl";
    };

    extraVolumes = [
      "/mnt/data/research:/mnt/data/research:ro"
    ];
  })

  # ── Personal agent ────────────────────────────────────────
  # Minimal profile, no extra volumes.
  (mkHermesAgent {
    name    = "personal";
    envFile = "/run/secrets/hermes-personal.env";

    extraEnvironment = {
      HERMES_PROFILE = "personal";
    };
  })

  # ── API bot agent ─────────────────────────────────────────
  # Headless API-only profile, no extra volumes.
  (mkHermesAgent {
    name    = "api-bot";
    envFile = "/run/secrets/hermes-api.env";

    extraEnvironment = {
      HERMES_PROFILE = "api";
    };
  })

  # ═══════════════════════════════════════════════════════════
  # Advanced examples — commented, uncomment and customize
  # ═══════════════════════════════════════════════════════════

  # ── Agent with custom Docker image ────────────────────────
  # (mkHermesAgent {
  #   name    = "custom-image";
  #   envFile = "/run/secrets/hermes-custom.env";
  #   image   = "my-registry/hermes-agent:custom-tag";
  # })

  # ── Agent with agenix secret (instead of envFile) ─────────
  # (mkHermesAgent {
  #   name        = "agenix-agent";
  #   agenixFile  = "/run/secrets/hermes-agenix-agent";
  #   extraEnvironment = {
  #     HERMES_PROFILE = "research";
  #   };
  # })

  # ── Agent with forced UID/GID ─────────────────────────────
  # (mkHermesAgent {
  #   name = "fixed-uid";
  #   uid  = 1500;
  #   gid  = 1500;
  #   envFile = "/run/secrets/hermes-fixed-uid.env";
  # })

  # ── Agent with memory limits and custom restart policy ────
  # (mkHermesAgent {
  #   name    = "restricted";
  #   envFile = "/run/secrets/hermes-restricted.env";
  #
  #   extraContainerConfig = {
  #     extraOptions = [
  #       "--memory=2g"
  #       "--memory-reservation=1g"
  #       "--cpus=1.0"
  #       "--restart=on-failure:5"
  #     ];
  #   };
  # })

  # ── Agent with stateDir override ──────────────────────────
  # (mkHermesAgent {
  #   name     = "data-agent";
  #   stateDir = "/mnt/data/hermes-bulk";
  #   envFile  = "/run/secrets/hermes-data.env";
  # })

  # ── Agent with autoStart disabled (manual start only) ─────
  # (mkHermesAgent {
  #   name       = "on-demand";
  #   envFile    = "/run/secrets/hermes-ondemand.env";
  #   autoStart  = false;
  # })

  # ── Agent with full Hermes YAML settings ───────────────────
  # Demonstrates the `settings` parameter — serialized to config.yaml
  # and mounted read-only at $HERMES_HOME/config.yaml.
  # Changes: nixos-rebuild → docker restart hermes-<name>
  #
  # ═══ Required .env vars (set in your envFile) ═══
  # OPENROUTER_API_KEY=sk-or-...    ← needed for ALL model routing
  # GROQ_API_KEY=gsk_...            ← needed for STT (groq whisper)
  # FIRECRAWL_API_KEY=fc-...        ← needed for web.backend = firecrawl
  #
  # ═══ MCP Server Note ═══
  # The hermès-agent Docker image is Python-based. It may NOT have
  # Node.js/npx. MCP servers using `npx` (like filesystem below)
  # will fail. Fixes:
  #   1. Build custom image extending hermès-agent with Node.js
  #   2. Use a Python-based MCP server instead
  #   3. Mount Node.js from host: extraVolumes = [ "/usr/bin/node:/usr/bin/node:ro" ]
  #
  # ═══ TTS Note ═══
  # Piper TTS needs voice files on disk (not in container by default).
  # Install on host and mount: extraVolumes = [ "/usr/share/piper-voices:/usr/share/piper-voices:ro" ]
  # Or switch to: tts.provider = "edge" (no extra files needed)
  #
  # ═══ Toolsets Note ═══
  # ["all"] enables every toolset including risky ones. Safer:
  #   toolsets = [ "terminal" "web" "memory" "file" "skills" ]
  #
  # (mkHermesAgent {
  #   name    = "primary";
  #   envFile = "/run/secrets/hermes-primary.env";
  #
  #   settings = {
  #     model = {
  #       default  = "deepseek/deepseek-v4-flash";
  #       provider = "openrouter";
  #       fallbacks = [
  #         { provider = "openrouter"; model = "google/gemini-2.5-flash-lite"; }
  #         { provider = "openrouter"; model = "deepseek/deepseek-v4-flash"; }
  #       ];
  #     };
  #
  #     auxiliary = {
  #       vision.model               = "anthropic/claude-haiku-4.5";
  #       vision.provider            = "openrouter";
  #       web_extract.model          = "deepseek/deepseek-v4-pro";
  #       web_extract.provider       = "openrouter";
  #       compression.model          = "deepseek/deepseek-v4-flash";
  #       compression.provider       = "openrouter";
  #       skills_hub.model           = "anthropic/claude-haiku-4.5";
  #       skills_hub.provider        = "openrouter";
  #       approval.model             = "deepseek/deepseek-v4-flash";
  #       approval.provider          = "openrouter";
  #       mcp.model                  = "anthropic/claude-haiku-4.5";
  #       mcp.provider               = "openrouter";
  #       triage_specifier.model     = "deepseek/deepseek-v4-flash";
  #       triage_specifier.provider  = "openrouter";
  #       profile_describer.model    = "anthropic/claude-haiku-4.5";
  #       profile_describer.provider = "openrouter";
  #       kanban_decomposer.model    = "deepseek/deepseek-v4-pro";
  #       kanban_decomposer.provider = "openrouter";
  #     };
  #
  #     stt.provider      = "groq";
  #     tts.provider      = "piper";
  #     tts.piper.voice   = "en_US-lessac-medium";
  #     voice.auto_tts    = true;
  #
  #     terminal = {
  #       backend = "local";
  #       cwd     = "/var/lib/hermes/workspace";
  #       timeout = 180;
  #     };
  #
  #     approvals.mode   = "smart";
  #     toolsets         = [ "all" ];   # Or explicit: ["terminal" "web" "memory" "file"]
  #
  #     compression = {
  #       enabled          = true;
  #       threshold        = 0.50;
  #       target_ratio     = 0.20;
  #       protect_last_n   = 20;
  #       protect_first_n  = 3;
  #     };
  #
  #     memory = {
  #       memory_enabled        = true;
  #       user_profile_enabled  = true;
  #     };
  #
  #     display = {
  #       tool_progress    = "off";
  #       busy_input_mode  = "queue";
  #       busy_ack_enabled = true;
  #     };
  #
  #     web.backend          = "firecrawl";
  #     cron.timezone        = "Europe/Vienna";
  #
  #     file_read_max_chars  = 100000;
  #     tool_output = {
  #       max_bytes  = 150000;
  #       max_lines  = 5000;
  #     };
  #
  #     # Requires Node.js in container — see notes above
  #     mcp_servers.filesystem = {
  #       command = "npx";
  #       args = [
  #         "-y"
  #         "@modelcontextprotocol/server-filesystem"
  #         "/home/tim/agent-config"
  #         "/var/lib/hermes/workspace"
  #       ];
  #     };
  #   };
  #
  #   extraPackages = with pkgs; [ bat curl fd git jq nix python3 ripgrep wget ];
  # })

  # ═══════════════════════════════════════════════════════════
  # Minimal quick-start — uncomment the block below and set
  # a single agent with just a name and env file.
  # ═══════════════════════════════════════════════════════════

  # (mkHermesAgent {
  #   name    = "default";
  #   envFile = "/run/secrets/hermes-default.env";
  # })
]
