{ mkHermesAgent }:

# ── Your agent definitions ──
# Copy this to my-agents.nix and customize.
#
# Usage in configuration.nix:
#   myAgents = import ./my-agents.nix { inherit mkHermesAgent; };
#   imports = myAgents;

[
  (mkHermesAgent {
    name = "default";
    # Path to env file with API keys (OPENROUTER_API_KEY, etc.)
    envFile = "/run/secrets/hermes-default.env";
  })
]
