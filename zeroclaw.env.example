# ────────────────────────────────────────────────────────────
# ZeroClaw agent environment variables
#
# Copy to /run/secrets/zeroclaw-<name>.env and fill in your keys
# (or encrypt with agenix and point agenixFile at the decrypted path).
#
#   sudo mkdir -p /run/secrets
#   sudo cp zeroclaw.env.example /run/secrets/zeroclaw-assistant.env
#   sudo chmod 600 /run/secrets/zeroclaw-assistant.env
#   sudo vi /run/secrets/zeroclaw-assistant.env
#
# ZeroClaw reads config overrides from the environment as
# ZEROCLAW_<section>__<sub>__<key> (double underscores between path
# segments), so API keys go in as provider config overrides.
# ────────────────────────────────────────────────────────────

# Required: API key for the provider configured in my-agents.nix
# (example: the `openrouter` provider from my-agents.nix.example)
ZEROCLAW_providers__models__openrouter__default__api_key=sk-or-...
